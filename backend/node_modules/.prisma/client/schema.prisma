datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             Int             @id @default(autoincrement())
  email          String          @unique
  name           String
  passwordHash   String
  role           String // "PATIENT", "DOCTOR", "ADMIN"
  createdAt      DateTime        @default(now())
  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  appointments   Appointment[]
  reviews        Review[]
  medicalRecords MedicalRecord[]
}

model PatientProfile {
  id              Int     @id @default(autoincrement())
  userId          Int     @unique
  age             Int?
  gender          String?
  phone           String?
  bloodType       String?
  medicalHistory  String? @db.Text
  weight          Float? // in kg
  bloodPressure   String? // e.g. "120/80"
  bloodSugar      Float? // in mg/dL
  sleepHours      Float? // in hours
  waterIntake     Float? // in Liters
  exerciseMinutes Int? // in minutes
  mood            String? // Vibe/mood state
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DoctorProfile {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique
  qualification  String
  experience     Int // in years
  specialization String // e.g. "Panchakarma Specialist", "Dermatology Ayurveda"
  languages      String // e.g. "English, Hindi, Sanskrit"
  fee            Float
  rating         Float          @default(5.0)
  clinicName     String
  bio            String         @db.Text
  status         String         @default("APPROVED") // "PENDING", "APPROVED", "SUSPENDED"
  isOnline       Boolean        @default(true)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilities Availability[]
  appointments   Appointment[]
  reviews        Review[]
}

model Availability {
  id        Int           @id @default(autoincrement())
  doctorId  Int
  dayOfWeek Int // 0-6 (Sunday to Saturday)
  startTime String // e.g. "09:00"
  endTime   String // e.g. "17:00"
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
}

model Appointment {
  id            Int           @id @default(autoincrement())
  patientId     Int
  doctorId      Int
  date          String // "YYYY-MM-DD"
  timeSlot      String // "09:30"
  status        String        @default("PENDING") // "PENDING", "CONFIRMED", "COMPLETED", "CANCELLED", "MISSED"
  notes         String?       @db.Text // Consultation notes written by doctor
  prescription  String?       @db.Text // Free-text prescription details
  medicinesJSON String?       @db.Text // JSON list of prescribed medicines
  receiptId     String? // Receipt ID for download
  doctor        DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       User          @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Review {
  id        Int           @id @default(autoincrement())
  patientId Int
  doctorId  Int
  rating    Float
  comment   String        @db.Text
  createdAt DateTime      @default(now())
  doctor    DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient   User          @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model MedicalRecord {
  id         Int      @id @default(autoincrement())
  patientId  Int
  fileName   String
  fileType   String // e.g. "application/pdf"
  fileUrl    String // local/mock URL
  uploadedAt DateTime @default(now())
  patient    User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model KnowledgeHubItem {
  id      Int     @id @default(autoincrement())
  type    String // "HERB", "DOSHA", "ARTICLE"
  title   String
  content String  @db.Text
  tags    String? // Comma-separated tags
  image   String? // Mock image URL or placeholder
}
